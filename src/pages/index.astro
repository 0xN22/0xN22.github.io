---
import Layout from "../layouts/IndexLayout.astro";
import '../styles/buttons.css';
---

<Layout hideFooter={true}>
  <main class="home">
    <div id="particles-js"></div>

    <section class="hero">
      <div class="hero-inner">
        <div class="name-wrap" id="name-wrap" style="opacity:0">
          <h1 class="name" id="name" data-text="N22">N22</h1>
          <span class="name-rule"></span>
        </div>

        <div class="info-block" id="info-block" style="opacity:0">
          <div class="info-row">
            <span class="info-key">location</span>
            <span class="info-sep">::</span>
            <span class="info-val redacted" id="redacted" data-text="[REDACTED]">[REDACTED]</span>
          </div>
          <div class="info-row">
            <span class="info-key">status</span>
            <span class="info-sep">::</span>
            <span class="info-val green">active</span>
          </div>
          <div class="info-row">
            <span class="info-key">focus</span>
            <span class="info-sep">::</span>
            <span class="info-val">security research</span>
          </div>
        </div>

        <div class="cta" id="cta" style="opacity:0">
          <a href="/about" class="cta-btn">
            <span class="span">about</span>
          </a>
          <a href="https://hackmd.io/@N22" class="cta-btn">
            <span class="span">writeups</span>
          </a>
        </div>

        <div class="status-bar" id="status-bar" style="opacity:0">
          <span class="dot"></span>
          <span>session active</span>
          <span class="divider">//</span>
          <span id="clock"></span>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Share+Tech+Mono&family=DM+Sans:wght@300;400&display=swap');

  .home {
    width: 100vw;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    position: relative;
  }

  #particles-js {
    position: fixed;
    inset: 0;
    z-index: 0;
    opacity: 0.4;
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .name-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .9rem;
    margin-bottom: 1.8rem;
    transition: opacity .4s ease;
  }

  .name {
    font-family: 'Black Ops One', sans-serif;
    font-size: clamp(4rem, 13vw, 7.5rem);
    letter-spacing: .06em;
    color: #fff;
    position: relative;
    line-height: 1;
    cursor: default;
  }

  .name::before, .name::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    opacity: 0;
  }

  .name::before {
    color: rgba(94, 123, 255, 0.85);
    clip-path: polygon(0 15%, 100% 15%, 100% 38%, 0 38%);
  }

  .name::after {
    color: rgba(255, 75, 130, 0.8);
    clip-path: polygon(0 58%, 100% 58%, 100% 78%, 0 78%);
  }

  .name.glitch-burst::before {
    animation: gb1 .6s steps(1) forwards;
  }

  .name.glitch-burst::after {
    animation: gb2 .6s steps(1) forwards;
  }

  @keyframes gb1 {
    0% { transform: translateX(-8px) skewX(-2deg); opacity: 1; }
    15% { transform: translateX(8px) skewX(2deg); opacity: 1; }
    30% { transform: translateX(-5px); opacity: 1; }
    45% { transform: translateX(5px); opacity: 1; }
    60% { transform: translateX(-3px); opacity: 1; }
    75% { transform: translateX(3px); opacity: 1; }
    90% { transform: translateX(-1px); opacity: .5; }
    100% { transform: translateX(0); opacity: 0; }
  }

  @keyframes gb2 {
    0% { transform: translateX(8px) skewX(2deg); opacity: 1; }
    15% { transform: translateX(-8px) skewX(-2deg); opacity: 1; }
    30% { transform: translateX(5px); opacity: 1; }
    45% { transform: translateX(-5px); opacity: 1; }
    60% { transform: translateX(3px); opacity: 1; }
    75% { transform: translateX(-3px); opacity: 1; }
    90% { transform: translateX(1px); opacity: .5; }
    100% { transform: translateX(0); opacity: 0; }
  }

  .name:hover::before {
    animation: g1 .45s steps(1) forwards;
  }

  .name:hover::after {
    animation: g2 .45s steps(1) forwards;
  }

  @keyframes g1 {
    0% { transform: translateX(-5px); opacity: 1; }
    25% { transform: translateX(5px); opacity: 1; }
    50% { transform: translateX(-3px); opacity: 1; }
    75% { transform: translateX(3px); opacity: 1; }
    100% { transform: translateX(0); opacity: 0; }
  }

  @keyframes g2 {
    0% { transform: translateX(5px); opacity: 1; }
    25% { transform: translateX(-5px); opacity: 1; }
    50% { transform: translateX(4px); opacity: 1; }
    75% { transform: translateX(-4px); opacity: 1; }
    100% { transform: translateX(0); opacity: 0; }
  }

  .name-rule {
    display: block;
    width: clamp(40px, 8vw, 70px);
    height: 2px;
    background: linear-gradient(90deg, transparent, #7c4dff, #5e7bff, transparent);
    border-radius: 2px;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    margin-bottom: 2rem;
    transition: opacity .4s ease;
  }

  .info-row {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(.72rem, 1.8vw, .82rem);
    letter-spacing: .08em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
  }

  .info-key {
    color: rgba(150, 140, 200, 0.5);
  }

  .info-sep {
    color: rgba(110, 75, 255, 0.4);
  }

  .info-val {
    color: rgba(200, 195, 230, 0.75);
  }

  .info-val.green {
    color: #4ade80;
  }

  .redacted {
    color: rgba(255, 75, 130, 0.8);
    letter-spacing: .12em;
    cursor: pointer;
    transition: color .15s;
  }

  .redacted:hover {
    color: rgba(255, 75, 130, 1);
  }

  .cta {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.2rem;
    transition: opacity .4s ease;
  }

  .status-bar {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    color: rgba(150, 140, 200, 0.4);
    letter-spacing: .1em;
    transition: opacity .4s ease;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
    animation: blink 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: .2; }
  }

  .divider {
    color: rgba(110, 75, 255, 0.3);
  }

  @keyframes fadeout {
    0% { opacity: 1; transform: translateY(0); }
    70% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-8px); }
  }

  .name-scan {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 255, 255, 0.06) 48%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.06) 52%,
      transparent 100%
    );
    animation: scan-sweep 0.8s ease-out forwards;
    pointer-events: none;
  }

  @keyframes scan-sweep {
    0% { transform: translateY(-100%); opacity: 1; }
    100% { transform: translateY(100%); opacity: 0; }
  }
</style>

<!-- Load particles library -->
<script is:inline src="/particles.min.js"></script>

<!-- Initialize particles -->
<script is:inline>
  window.addEventListener('load', () => {
    if (window.particlesJS) {
      window.particlesJS("particles-js", {
        particles: {
          number: { value: 80 },
          color: { value: "#00ff88" },
          shape: { type: "circle" },
          size: { value: 4, random: true },
          opacity: { value: 0.6, random: true },
          move: { enable: true, speed: 2 },
          line_linked: { 
            enable: true, 
            distance: 200,
            color: "#00ff88",
            opacity: 0.5 
          }
        },
        interactivity: {
          detect_on: "canvas",
          events: { onhover: { enable: true, mode: "repulse" } }
        }
      });
    }
  });
</script>

<!-- Animation script -->
<script is:inline>
  const nameWrap = document.getElementById('name-wrap');
  const nameEl = document.getElementById('name');
  const infoBlock = document.getElementById('info-block');
  const ctaEl = document.getElementById('cta');
  const statusEl = document.getElementById('status-bar');
  const redacted = document.getElementById('redacted');

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

  async function run() {
    await sleep(200);
    nameWrap.style.opacity = '1';
    nameEl.classList.add('glitch-burst');

    const scan = document.createElement('div');
    scan.className = 'name-scan';
    nameEl.appendChild(scan);
    setTimeout(() => scan.remove(), 900);

    await sleep(700);
    nameEl.classList.remove('glitch-burst');
    await sleep(200);
    infoBlock.style.opacity = '1';
    await sleep(300);
    ctaEl.style.opacity = '1';
    await sleep(200);
    statusEl.style.opacity = '1';
  }

  run();

  const scrambleChars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*';
  const originalText = '[REDACTED]';
  let scrambleInterval = null;
  let isScrambling = false;

  redacted.addEventListener('mouseenter', () => {
    if (isScrambling) return;
    isScrambling = true;
    let iterations = 0;
    const maxIterations = 18;
    scrambleInterval = setInterval(() => {
      redacted.textContent = originalText
        .split('')
        .map((char, i) => {
          if (char === '[' || char === ']' || char === ' ') return char;
          if (i < iterations / 2) return originalText[i];
          return scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
        })
        .join('');
      iterations++;
      if (iterations >= maxIterations) {
        clearInterval(scrambleInterval);
        redacted.textContent = originalText;
        isScrambling = false;
      }
    }, 40);
  });

  const clockEl = document.getElementById('clock');
  function updateClock() {
    clockEl.textContent = new Date().toLocaleTimeString('en-GB', { hour12: false });
  }
  updateClock();
  setInterval(updateClock, 1000);

  let typed = '';
  document.addEventListener('keydown', (e) => {
    typed += e.key.toLowerCase();
    if (typed.length > 10) typed = typed.slice(-10);
    if (typed.includes('sudo')) {
      typed = '';
      const hero = document.querySelector('.hero-inner');
      const line = document.createElement('div');
      line.style.cssText = `
        font-family: 'Share Tech Mono', monospace;
        font-size: .75rem;
        color: rgba(255,80,80,0.8);
        letter-spacing: .08em;
        margin-bottom: .8rem;
        animation: fadeout 2.5s forwards;
      `;
      line.textContent = 'sudo: permission denied';
      hero.insertBefore(line, hero.firstChild);
      setTimeout(() => line.remove(), 2500);
    }
  });
</script>